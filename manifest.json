{
  "key": "",
  "name": "页面辅助工具",
  "version": "1.9.6",
  "description": "页面功能辅助扩展",
  "icons": {
    "48": "assets/icon.png",
    "128": "assets/icon.png"
  },
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "downloads",
    "pageCapture"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["utils/debugCapture.js"],
      "run_at": "document_start",
      "all_frames": false
    },
    {
      "matches": ["<all_urls>"],
      "js": [
        "utils/common.js",
        "utils/textNormalize.js",
        "utils/db.js",
        "libs/xlsx.mini.js",
        "content/questionFinder.js",
        "content/matcher.js",
        "content/floatPanel.js",
        "content/bankManager.js",
        "content/content.js"
      ],
      "css": ["content/content.css"],
      "all_frames": true,
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "页面辅助工具"
  },
  "commands": {
    "toggle-helper": {
      "suggested_key": {
        "default": "Ctrl+Shift+E"
      },
      "description": "普通模式开关（含悬浮窗）"
    },
    "toggle-stealth": {
      "suggested_key": {
        "default": "Ctrl+Shift+H"
      },
      "description": "隐形模式开关（纯后台作答，无界面）"
    },
    "save-page": {
      "suggested_key": {
        "default": "Ctrl+Shift+S"
      },
      "description": "后台保存当前页面（不弹窗、不失焦）"
    }
  }
}
