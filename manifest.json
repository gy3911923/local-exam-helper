{
  "manifest_version": 3,
  "name": "本地题库答题助手",
  "version": "1.0.0",
  "description": "基于自有本地题库，自动识别网页考试题目并匹配作答。纯本地运行，零切屏风险。",
  "icons": {
    "48": "assets/icon.png",
    "128": "assets/icon.png"
  },
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "utils/common.js",
        "utils/textNormalize.js",
        "utils/db.js",
        "libs/xlsx.mini.js",
        "content/questionFinder.js",
        "content/matcher.js",
        "content/floatPanel.js",
        "content/bankManager.js",
        "content/content.js"
      ],
      "css": ["content/content.css"],
      "all_frames": true,
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "本地题库答题助手"
  },
  "commands": {
    "toggle-helper": {
      "suggested_key": {
        "default": "Ctrl+Shift+E"
      },
      "description": "开启/关闭答题助手"
    }
  }
}
